# AG-Forge 환경변수 설정
# 이 파일을 복사하여 .env 로 저장하세요
# cp .env.example .env

# ── 필수 ─────────────────────────────────────
# 모바일 접속 비밀번호 (길고 복잡하게 설정하세요)
AG_FORGE_API_KEY=your-secret-key-here

# ── Gemini API (뇌 실제 구동 시 필요) ─────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── ngrok 터널 (외부 접속 시 필요) ────────────
# https://dashboard.ngrok.com/get-started/your-authtoken 에서 발급
NGROK_AUTHTOKEN=your-ngrok-token-here

# ── 서버 설정 (선택) ───────────────────────────
HOST=0.0.0.0
PORT=8000
